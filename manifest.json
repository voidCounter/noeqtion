{
  "manifest_version": 3,
  "name": "Notion Math Converter",
  "version": "1.0",
  "description": "Converts LaTeX-style math equations to Notion's native format.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.notion.so/*",
    "https://*.notion.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.notion.so/*",
        "https://*.notion.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}